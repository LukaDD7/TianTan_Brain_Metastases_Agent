{
  "template_info": {
    "name": "ASCO/NCCN 脑转移瘤诊疗 Order Sets 模板",
    "version": "2026.v2",
    "source": "NCCN CNS Cancers v3.2024 + ASCO Brain Mets Guideline 2022",
    "purpose": "结构化临床决策输出，强制填空式生成",
    "dynamic_template_notice": {
      "title": "⚠️ 动态可选模板声明",
      "content": "这是一个动态可选模板。如果患者的治疗决策不包含某项治疗（例如患者无法手术或不符合放疗指征），必须将对应模块（如 surgery）设为 null，绝对不可为了填表而捏造不适用的治疗细节。被排除的疗法应详细记录在 rejected_alternatives 模块中，并说明排除原因和循证依据。",
      "example": {
        "scenario": "患者 KPS 40，多发脑转移，不适合手术",
        "correct_handling": {
          "primary_plan": {
            "modality": "radiotherapy",
            "surgery": null,
            "radiotherapy": { "technique": "WBRT", ... }
          },
          "rejected_alternatives": {
            "rejected_options": [
              {
                "option": "手术切除",
                "reason": "患者 KPS 评分过低 (40 分)，且为多发脑转移，手术风险大于获益",
                "evidence_level": "NCCN Category 2A",
                "citation": { "source": "NCCN CNS Cancers v3.2024", "section": "Principles of Surgical Resection" }
              }
            ]
          }
        }
      }
    }
  },

  "output_schema": {
    "admission_evaluation": {
      "title": "入院评估与一般治疗",
      "description": "入院时的一般状况评估和支持治疗，严禁写入'术前准备'等暗示性文字",
      "mandatory_warning": "⚠️ 本模块仅描述入院评估和对症治疗，严禁出现'术前准备'、'拟行手术'等暗示必然手术的文字",
      "fields": {
        "performance_status": {
          "type": "string",
          "enum": ["KPS ≥70", "KPS 50-60", "KPS <50"],
          "required": true,
          "description": "Karnofsky 体力状态评分"
        },
        "neurological_status": {
          "type": "string",
          "description": "神经系统状态描述，包括意识水平、局灶体征、癫痫发作史等",
          "required": true,
          "example": "神志清楚，右侧肢体肌力 IV 级，无癫痫发作史"
        },
        "symptom_management": {
          "type": "array",
          "items": {
            "medication": {
              "type": "string",
              "description": "药物通用名",
              "example": "地塞米松"
            },
            "indication": {
              "type": "string",
              "description": "适应证",
              "example": "脑水肿"
            },
            "dosage": {
              "type": "string",
              "description": "必须写明具体剂量",
              "example": "10mg"
            },
            "frequency": {
              "type": "string",
              "description": "给药频次",
              "example": "QD, BID, Q8H"
            },
            "tapering_schedule": {
              "type": "string",
              "description": "【类固醇强制字段】如果药物是类固醇（如地塞米松、甲泼尼龙），必须填写减量计划。例如：'症状改善后每 3 天减量 2mg，直至停药' 或 '无需减量，短期使用'",
              "required_for_corticosteroids": true,
              "example": "神经症状稳定后每 3-5 天减量 2-4mg，目标最低有效剂量或停药"
            }
          },
          "required": false
        },
        "baseline_labs": {
          "type": "array",
          "items": "string",
          "description": "基线检查项目",
          "required": true,
          "example": ["血常规", "肝肾功能", "电解质", "凝血功能", "心电图"]
        },
        "baseline_imaging": {
          "type": "array",
          "items": "string",
          "description": "基线影像学检查",
          "required": true,
          "example": ["头颅 MRI 增强", "胸部 CT", "腹部 CT/MRI", "全身骨扫描"]
        }
      }
    },

    "primary_plan": {
      "title": "首选治疗方案",
      "description": "根据 MDT 讨论确定的首选治疗，必须写明具体执行细节",
      "dynamic_template_notice": "如果患者不适合某种治疗方式，将对应模块设为 null，并在 rejected_alternatives 中说明排除原因",
      "modality_selector": {
        "enum": ["surgery", "radiotherapy", "systemic_therapy", "combined"],
        "required": true,
        "description": "选择首选治疗方式：surgery（手术）、radiotherapy（放疗）、systemic_therapy（全身治疗）、combined（联合治疗）"
      },
      "modalities": {
        "surgery": {
          "type": "object|null",
          "description": "手术治疗模块。如患者不适合手术，此字段应为 null",
          "required_if_modality_includes_surgery": true,
          "fields": {
            "procedure_name": {
              "type": "string",
              "description": "手术名称",
              "example": "开颅颅内占位性病变切除术"
            },
            "surgical_adjuncts": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "术中神经导航",
                  "术中核磁共振",
                  "术中电生理监测",
                  "术中超声",
                  "5-ALA 荧光引导",
                  "术中唤醒"
                ]
              },
              "description": "必须明确是否使用辅助技术，如不适用请填写'无'",
              "required": true,
              "example": ["术中神经导航", "术中电生理监测"]
            },
            "extent_of_resection_goal": {
              "type": "string",
              "enum": ["GTR (全切)", "STR (次全切)", "Biopsy Only (仅活检)"],
              "description": "预期切除范围",
              "required": true
            },
            "molecular_pathology_orders": {
              "type": "array",
              "items": {
                "type": "string",
                "description": "分子病理检测项目"
              },
              "description": "【核心新增】分子病理送检医嘱。必须明确切除组织需进行哪些基因突变检测，用于指导后续靶向/免疫治疗",
              "required": true,
              "example": [
                "BRAF V600E 免疫组化",
                "NGS 泛癌种 425 基因 panel（包括 EGFR、ALK、ROS1、KRAS、PIK3CA 等）",
                "MMR 蛋白免疫组化（MLH1、MSH2、MSH6、PMS2）",
                "PD-L1 免疫组化（22C3 抗体，CPS 评分）"
              ]
            }
          }
        },
        "radiotherapy": {
          "type": "object|null",
          "description": "放射治疗模块。如患者不适合放疗，此字段应为 null",
          "required_if_modality_includes_radiotherapy": true,
          "fields": {
            "technique": {
              "type": "string",
              "enum": ["SRS", "FSRT", "WBRT", "WBRT+SRS Boost", "IMRT", "海马回避 WBRT"],
              "description": "放疗技术",
              "required": true
            },
            "dose_fractionation": {
              "type": "object",
              "properties": {
                "total_dose_gy": { "type": "number", "description": "总剂量 (Gy)" },
                "fractions": { "type": "number", "description": "分割次数" },
                "dose_per_fraction_gy": { "type": "number", "description": "单次剂量 (Gy)" }
              },
              "required": true,
              "example": { "total_dose_gy": 30, "fractions": 10, "dose_per_fraction_gy": 3 }
            },
            "target_definition": {
              "type": "object",
              "properties": {
                "gtv": { "type": "string", "description": "GTV 定义" },
                "ptv_margin": { "type": "string", "description": "PTV 外放边界" },
                "oars_constraints": { "type": "array", "items": "string", "description": "危及器官限量" }
              },
              "required": true
            },
            "concurrent_medications": {
              "type": "array",
              "items": "string",
              "description": "围放疗期用药（如预防性止吐、激素等）",
              "required": false
            }
          }
        },
        "systemic_therapy": {
          "type": "object|null",
          "description": "全身治疗模块（靶向/免疫/化疗）。如患者不适合全身治疗，此字段应为 null",
          "required_if_modality_includes_systemic": true,
          "fields": {
            "regimen_name": {
              "type": "string",
              "description": "方案名称",
              "example": "Osimertinib 单药方案"
            },
            "drugs": {
              "type": "array",
              "items": {
                "drug_name": {
                  "type": "string",
                  "description": "药物通用名",
                  "required": true
                },
                "dosage": {
                  "type": "string",
                  "description": "必须写明具体剂量，如'80mg'",
                  "required": true,
                  "example": "80mg"
                },
                "route": {
                  "type": "string",
                  "description": "给药途径",
                  "required": true,
                  "example": "PO"
                },
                "frequency": {
                  "type": "string",
                  "description": "给药频率",
                  "required": true,
                  "example": "QD"
                },
                "cycle_length": {
                  "type": "number",
                  "description": "周期长度（天），如 21 天为一周期",
                  "required": true,
                  "example": 21
                },
                "interval": {
                  "type": "string",
                  "description": "给药间隔描述",
                  "required": true,
                  "example": "每日一次，连续服用"
                },
                "duration": {
                  "type": "string",
                  "description": "总疗程",
                  "required": true,
                  "example": "直至疾病进展或不可耐受毒性"
                },
                "peri_procedural_holding_parameters": {
                  "type": "string",
                  "description": "【核心新增】围手术期/放疗期停药要求。例如：'SRS 治疗前后需停用 BRAF 抑制剂 3 天以防放射性脑坏死' 或 '手术前后停药 7 天'",
                  "required": false,
                  "example": "SRS 治疗前后各停药 3 天，以降低放射性脑坏死风险"
                },
                "food_requirements": {
                  "type": "string",
                  "description": "饮食要求（如空腹、餐后等）",
                  "required": false
                },
                "major_toxicities": {
                  "type": "array",
                  "items": "string",
                  "description": "主要毒性反应",
                  "required": false
                }
              },
              "required": true
            },
            "biomarker_requirement": {
              "type": "string",
              "description": "生物标志物要求（如 EGFR 突变阳性）",
              "required": false
            }
          }
        }
      },
      "rationale": {
        "type": "string",
        "description": "选择该方案的理由",
        "required": true
      },
      "evidence_citation": {
        "type": "string",
        "description": "指南引用，格式：[Citation: 文件名，Page 页码]",
        "required": true
      }
    },

    "systemic_management": {
      "title": "后续治疗与全身管理",
      "description": "术后/放疗后的全身治疗和维持治疗",
      "fields": {
        "targeted_therapy": {
          "type": "object|null",
          "properties": {
            "gene_target": {
              "type": "string",
              "description": "靶基因，如'EGFR'、'ALK'、'BRAF'",
              "required": true
            },
            "variant": {
              "type": "string",
              "description": "变异类型，如'L858R'、'V600E'",
              "required": true
            },
            "drug": {
              "type": "string",
              "description": "药物名称",
              "required": true
            },
            "dosage": {
              "type": "string",
              "description": "剂量",
              "required": true
            },
            "cycle_length": {
              "type": "number",
              "description": "周期长度（天）",
              "required": true
            },
            "interval": {
              "type": "string",
              "description": "给药间隔",
              "required": true
            },
            "duration": {
              "type": "string",
              "description": "总疗程",
              "required": true
            },
            "peri_procedural_holding_parameters": {
              "type": "string",
              "description": "【核心新增】围手术期/放疗期停药要求",
              "required": false,
              "example": "SRS 治疗前后各停药 3 天，以降低放射性脑坏死风险"
            }
          },
          "required": false
        },
        "immunotherapy": {
          "type": "object|null",
          "properties": {
            "agent": {
              "type": "string",
              "description": "免疫治疗药物",
              "required": true
            },
            "dosage": {
              "type": "string",
              "description": "剂量",
              "required": true
            },
            "cycle_length": {
              "type": "number",
              "description": "周期长度（天）",
              "required": true
            },
            "duration": {
              "type": "string",
              "description": "总疗程",
              "required": true
            },
            "peri_procedural_holding_parameters": {
              "type": "string",
              "description": "围手术期/放疗期停药要求",
              "required": false
            }
          },
          "required": false
        },
        "cns_prophylaxis": {
          "type": "string",
          "description": "CNS 预防策略（如需要）",
          "required": false
        },
        "maintenance_plan": {
          "type": "string",
          "description": "维持治疗计划",
          "required": false
        },
        "bone_modifying_agent": {
          "type": "string",
          "description": "骨改良药物（如地舒单抗、唑来膦酸），用于预防骨相关事件",
          "required": false
        }
      }
    },

    "follow_up": {
      "title": "全程管理与随访计划",
      "description": "治疗后的随访和监测计划",
      "fields": {
        "imaging_schedule": {
          "type": "array",
          "items": {
            "modality": {
              "type": "string",
              "description": "检查类型",
              "example": "MRI Brain"
            },
            "frequency": {
              "type": "string",
              "description": "频率",
              "example": "每 2-3 个月"
            },
            "duration": {
              "type": "string",
              "description": "持续时间",
              "example": "前 2 年，之后每 6 个月"
            }
          },
          "required": true
        },
        "tumor_markers": {
          "type": "array",
          "items": "string",
          "description": "肿瘤标志物监测",
          "required": false
        },
        "clinical_visit_schedule": {
          "type": "string",
          "description": "门诊复诊频率",
          "required": true,
          "example": "每周期治疗前复诊，或出现新发症状时随诊"
        },
        "toxicity_monitoring": {
          "type": "array",
          "items": {
            "parameter": {
              "type": "string",
              "description": "监测参数"
            },
            "frequency": {
              "type": "string",
              "description": "监测频率"
            }
          },
          "description": "毒性监测计划",
          "required": true,
          "example": [
            { "parameter": "肝功能", "frequency": "每周期前" },
            { "parameter": "心电图", "frequency": "基线及每 3 个月" },
            { "parameter": "甲状腺功能", "frequency": "每 6 周（免疫治疗）" }
          ]
        },
        "emergency_contact_criteria": {
          "type": "array",
          "items": "string",
          "description": "急诊就诊指征",
          "required": false,
          "example": ["新发或加重的头痛", "癫痫发作", "肢体无力或感觉异常", "意识状态改变"]
        }
      }
    },

    "rejected_alternatives": {
      "title": "不推荐/被排除的治疗方案",
      "description": "极其重要！列出考虑过但不推荐的方案，并给出排除原因。推荐与排除的原因都必须带有 OncoKB 或 PubMed/NCCN/ESMO 指南的明确引用",
      "mandatory_warning": "⚠️ 本模块为强制必填，即使所有其他治疗方案都被排除，也必须说明原因",
      "fields": {
        "rejected_options": {
          "type": "array",
          "min_items": 1,
          "items": {
            "option": {
              "type": "string",
              "description": "被排除的方案",
              "required": true,
              "example": "手术切除"
            },
            "reason": {
              "type": "string",
              "description": "排除原因（必须具体说明医学理由）",
              "required": true,
              "example": "患者 KPS 评分过低 (40 分)，且为多发脑转移，手术风险大于获益"
            },
            "evidence_level": {
              "type": "string",
              "enum": [
                "NCCN Category 1",
                "NCCN Category 2A",
                "NCCON Category 2B",
                "NCCON Category 3",
                "ESMO Level I",
                "ESMO Level II",
                "ESMO Level III",
                "Expert Opinion"
              ],
              "description": "证据等级",
              "required": true
            },
            "citation": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string",
                  "description": "来源（如'NCCN CNS Cancers v3.2024'、'OncoKB'、'PubMed PMID: XXXXXXXX'）",
                  "required": true
                },
                "section": {
                  "type": "string",
                  "description": "具体章节或描述",
                  "required": false
                },
                "pmid": {
                  "type": "string",
                  "description": "PubMed ID（如适用）",
                  "required": false
                }
              },
              "required": true
            }
          },
          "required": true
        }
      }
    },

    "agent_trace": {
      "title": "Agent 推理追踪记录",
      "description": "附加 Agent 本次推理的工具调用记录，确保透明可追溯。用于 QA 审核和 Agent 行为分析",
      "fields": {
        "skills_called": {
          "type": "array",
          "items": {
            "skill_name": {
              "type": "string",
              "description": "Skill 名称"
            },
            "query_type": {
              "type": "string",
              "description": "查询类型（如适用）"
            },
            "key_findings": {
              "type": "array",
              "items": "string",
              "description": "关键发现摘要"
            },
            "duration_ms": {
              "type": "number",
              "description": "耗时（毫秒）"
            },
            "timestamp": {
              "type": "string",
              "description": "时间戳（ISO 8601 格式）"
            }
          },
          "description": "本次推理调用的所有 Skill 记录"
        },
        "evidence_sources": {
          "type": "array",
          "items": {
            "source_type": {
              "type": "string",
              "enum": ["OncoKB", "PubMed", "NCCN", "ESMO", "ASCO", "CSCO"]
            },
            "source_id": {
              "type": "string",
              "description": "来源 ID（如 PMID、证据 UUID、指南版本号）"
            },
            "relevance": {
              "type": "string",
              "description": "与当前决策的相关性描述"
            }
          },
          "description": "引用的所有循证医学证据来源"
        },
        "reasoning_confidence": {
          "type": "string",
          "enum": ["High", "Moderate", "Low"],
          "description": "基于证据充分性的自我评估",
          "required": true
        },
        "uncertainty_factors": {
          "type": "array",
          "items": "string",
          "description": "影响决策信心的不确定因素",
          "required": false
        }
      }
    }
  },

  "clinical_reference_summary": {
    "corticosteroid_management": {
      "guideline": "NCCN CNS Cancers v3.2024 + ASCO Brain Mets 2022",
      "recommendations": [
        "地塞米松是首选类固醇（最小生物等价物半衰期）",
        "有症状的脑水肿：起始 4-8mg/天，严重症状可达 16mg/天",
        "无症状患者不推荐常规使用类固醇",
        "应在神经症状稳定后尽快开始减量，目标最低有效剂量或停药",
        "长期使用者需预防肺孢子菌肺炎（SMX-TMP）"
      ]
    },
    "peri_procedural_holding": {
      "guideline": "ASTRO/ASCO Consensus 2022",
      "recommendations": [
        "SRS 前后停用 BRAF/MEK 抑制剂各 3 天，以降低放射性脑坏死风险",
        "免疫治疗（PD-1/PD-L1）与 SRS 联合时，建议停药 1 周以降低神经毒性",
        "抗血管生成药物（如贝伐珠单抗）手术前后需停药 6-8 周以防伤口愈合并发症"
      ]
    },
    "molecular_profiling": {
      "guideline": "NCCN CNS Cancers v3.2024 + ESMO Precision Medicine",
      "recommendations": [
        "所有非小细胞肺癌脑转移患者应进行 EGFR、ALK、ROS1、BRAF、KRAS、MET、RET、NTRK 检测",
        "黑色素瘤脑转移应进行 BRAF V600 检测",
        "推荐 NGS 多基因 panel 检测，优先于单基因检测",
        "MMR/MSI 状态用于预测免疫治疗获益"
      ]
    }
  }
}
